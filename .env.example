# ==============================================================================
# AGENDA INTELIGENTE - CONFIGURAÇÃO DE AMBIENTE (DEPLOY VERCEL & CLOUD)
# ==============================================================================
# Adicione estas variáveis nas configurações de seu deploy na Vercel (Environment Variables) 
# ou no arquivo local `.env` se for executar o projeto localmente via `npm run dev`.

# 1. LINK DE INSTANCIAÇÃO PRINCIPAL
# APP_URL: A URL final sob a qual o aplicativo se encontra hospedado.
# (Automatizado no Google Cloud Run, preencher na Vercel se necessário)
APP_URL="https://agenda-inteligente-sua-url.vercel.app"

# 2. INTELIGÊNCIA ARTIFICIAL (GEMINI API)
# Deixe configurado apenas em ambiente server-side se for proxyar chamadas,
# ou insira se o aplicativo precisar de acesso direito a recursos inteligentes.
GEMINI_API_KEY=""

# 3. CONEXÃO COM SUPABASE (BANCO DE DADOS ALTERNATIVO)
# Se estiver utilizando o Supabase para salvar dados persistentes ao invés do Firebase local/demo.
VITE_SUPABASE_URL="https://vvlhvkxjanpjxjeefzar.supabase.co"
VITE_SUPABASE_ANON_KEY=""

# NOTA SOBRE FIREBASE:
# O Firebase neste projeto é autogerenciado através do arquivo local `firebase-applet-config.json`.
# Para rodar com outro projeto, basta colar as credenciais geradas pelo console do Firebase
# no arquivo `firebase-applet-config.json` na raiz da aplicação.
