{
  "entities": {
    "barber_settings": {
      "title": "BarberSettings",
      "description": "Configurações do perfil e funcionamento da barbearia",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Nome da barbearia" },
        "address": { "type": "string", "description": "Endereço físico" },
        "phone": { "type": "string", "description": "Telefone e WhatsApp para contato" },
        "logoUrl": { "type": "string", "description": "URL com o logo da barbearia" },
        "startHour": { "type": "string", "description": "Horário de início (HH:MM)" },
        "endHour": { "type": "string", "description": "Horário de término (HH:MM)" },
        "workingDays": { "type": "array", "description": "Dias de funcionamento na semana (0-6)" }
      },
      "required": ["name", "address", "phone"]
    },
    "services": {
      "title": "Services",
      "description": "Catálogo de serviços oferecidos pela barbearia",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "price": { "type": "number" },
        "duration": { "type": "number", "description": "Duração em minutos" },
        "description": { "type": "string" }
      },
      "required": ["name", "price", "duration"]
    },
    "bookings": {
      "title": "Bookings",
      "description": "Agendamentos de horários de clientes na barbearia",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "clientName": { "type": "string" },
        "clientWhatsApp": { "type": "string" },
        "serviceId": { "type": "string" },
        "serviceName": { "type": "string" },
        "servicePrice": { "type": "number" },
        "date": { "type": "string", "format": "date", "description": "Data no formato YYYY-MM-DD" },
        "time": { "type": "string", "description": "Horário no formato HH:MM" },
        "status": { "type": "string", "enum": ["agendado", "concluido", "cancelado"] },
        "notes": { "type": "string" },
        "paymentMethod": { "type": "string", "enum": ["pix", "dinheiro", "cartao"] },
        "createdAt": { "type": "string" }
      },
      "required": ["clientName", "clientWhatsApp", "serviceId", "serviceName", "servicePrice", "date", "time", "status"]
    },
    "clients": {
      "title": "Clients",
      "description": "Registro completo dos clientes da barbearia",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "whatsapp": { "type": "string" },
        "birthDate": { "type": "string" },
        "notes": { "type": "string" },
        "createdAt": { "type": "string" },
        "totalBookings": { "type": "number" },
        "totalSpent": { "type": "number" }
      },
      "required": ["name", "whatsapp"]
    },
    "transactions": {
      "title": "Transactions",
      "description": "Controle financeiro de receitas e despesas",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string", "enum": ["receita", "despesa"] },
        "amount": { "type": "number" },
        "date": { "type": "string" },
        "description": { "type": "string" },
        "paymentMethod": { "type": "string", "enum": ["pix", "dinheiro", "cartao"] },
        "bookingId": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["type", "amount", "date", "description"]
    }
  },
  "firestore": {
    "settings/barber": {
      "schema": "barber_settings",
      "description": "Configurações globais da barbearia"
    },
    "services/{serviceId}": {
      "schema": "services",
      "description": "Opções de corte, barba e outros serviços criados pelo barbeiro"
    },
    "bookings/{bookingId}": {
      "schema": "bookings",
      "description": "Agendamentos de horários de clientes"
    },
    "clients/{clientId}": {
      "schema": "clients",
      "description": "Registro detalhado de clientes que agendaram ou foram inseridos"
    },
    "transactions/{transactionId}": {
      "schema": "transactions",
      "description": "Entradas de faturamento vinculadas a agendamentos ou avulsas"
    }
  }
}
