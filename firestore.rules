rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global default-deny catch-all safety net
    match /{document=**} {
      allow read, write: if false;
    }

    // Custom Helpers
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // 1. Settings Collection Rules
    match /settings/{docId} {
      allow read: if true; // Public access for client area to see details
      allow write: if isSignedIn(); // Administrative changes only
    }

    // 2. Services Collection Rules
    match /services/{serviceId} {
      allow read: if true; // Public access for client scheduling
      allow create, update, delete: if isSignedIn();
    }

    // 3. Bookings Collection Rules
    match /bookings/{bookingId} {
      allow get: if true; // Anyone can get by ID (success screen/direct link)
      allow list: if isSignedIn() || (resource.data.clientWhatsApp != null); // Public queries restricted to filter match
      
      // Standard booking schema validation
      function isValidBooking(data) {
        return data.clientName is string && data.clientName.size() <= 200 &&
               data.clientWhatsApp is string && data.clientWhatsApp.size() <= 50 &&
               data.serviceId is string &&
               data.serviceName is string &&
               data.servicePrice is number &&
               data.date is string && data.date.size() == 10 &&
               data.time is string && data.time.size() == 5 &&
               data.status in ['agendado', 'concluido', 'cancelado'];
      }

      allow create: if isValidBooking(incoming());
      
      allow update: if isSignedIn() || (
        // Public booking cancellation validation
        incoming().status == 'cancelado' &&
        incoming().clientName == existing().clientName &&
        incoming().clientWhatsApp == existing().clientWhatsApp &&
        // Protect other fields from modification
        incoming().date == existing().date &&
        incoming().time == existing().time &&
        incoming().serviceId == existing().serviceId &&
        incoming().servicePrice == existing().servicePrice
      );
      
      allow delete: if isSignedIn();
    }

    // 4. Clients Collection Rules
    match /clients/{clientId} {
      allow get: if true; // Public can get exact client document if they have the ID
      allow list: if isSignedIn() || (resource.data.whatsapp != null); // Allow admin or public filter query
      allow create: if true; // Allow client auto-registration upon public booking
      allow update: if isSignedIn() || (incoming().whatsapp == existing().whatsapp);
      allow delete: if isSignedIn();
    }

    // 5. Transactions Collection Rules
    match /transactions/{transactionId} {
      allow read, write: if isSignedIn(); // Financial records must be strictly isolated to administrative access
    }
  }
}
